generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 작가 모델
model Artist {
  id           String       @id @default(cuid())
  name         String
  imageUrl     String?      // 작가 사진 (선택사항, 기존 호환용)
  biography    String?      // 약력 (선택사항)
  introduction String?      // 소개 (선택사항)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  exhibitions  ExhibitionArtist[]
  images       ArtistImage[]
  // 기존 관계 유지 (마이그레이션 후 제거 예정)
  oldExhibitions Exhibition[] @relation("OldArtistRelation")
}

// 작가 이미지 모델
model ArtistImage {
  id           String   @id @default(cuid())
  imageUrl     String
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  artistId     String
  artist       Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
}

// 전시회 모델
model Exhibition {
  id          String            @id @default(cuid())
  title       String
  description String?           // 전시회 설명 (선택사항)
  imageUrl    String            // 대표 이미지
  startDate   DateTime          @default(now())
  endDate     DateTime          @default(now())
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  // 기존 필드 유지 (마이그레이션 후 제거 예정)
  artistId    String?
  artist      Artist?           @relation("OldArtistRelation", fields: [artistId], references: [id], onDelete: SetNull)
  // 새로운 다대다 관계
  artists     ExhibitionArtist[]
  images      ExhibitionImage[]
}

// 전시회-작가 다대다 관계 테이블
model ExhibitionArtist {
  id           String     @id @default(cuid())
  exhibitionId String
  artistId     String
  exhibition   Exhibition @relation(fields: [exhibitionId], references: [id], onDelete: Cascade)
  artist       Artist     @relation(fields: [artistId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([exhibitionId, artistId])
}

// 전시회 추가 이미지 모델
model ExhibitionImage {
  id           String     @id @default(cuid())
  imageUrl     String
  displayOrder Int        @default(0)
  createdAt    DateTime   @default(now())
  exhibitionId String
  exhibition   Exhibition @relation(fields: [exhibitionId], references: [id], onDelete: Cascade)
}

// 홈 화면 슬라이더 이미지 모델
model HomeImage {
  id           String   @id @default(cuid())
  imageUrl     String
  title        String?  // 슬라이드 제목 (선택사항)
  subtitle     String?  // 슬라이드 부제목 (선택사항)
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// 공간 예약 문의 모델
model Booking {
  id            String   @id @default(cuid())
  name          String   // 예약자 이름
  phone         String   // 전화번호
  email         String   // 이메일
  startDate     DateTime @default(now()) // 대관 시작일
  endDate       DateTime @default(now()) // 대관 종료일
  message       String?  // 전시 컨셉/메시지
  isRead        Boolean  @default(false) // 관리자 읽음 여부
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// 공지사항 모델
model Notice {
  id          String             @id @default(cuid())
  title       String
  content     String
  isFeatured  Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  attachments NoticeAttachment[]
}

// 공지사항 첨부파일 모델
model NoticeAttachment {
  id        String   @id @default(cuid())
  fileName  String
  fileUrl   String
  fileSize  Int?
  mimeType  String?
  createdAt DateTime @default(now())
  noticeId  String
  notice    Notice   @relation(fields: [noticeId], references: [id], onDelete: Cascade)
}

// 예약 불가 날짜 모델
model UnavailableDate {
  id           String   @id @default(cuid())
  date         DateTime // 예약 불가 날짜
  reason       String?  // 사유 (예: "전시: OOO전", "휴관")
  type         String   // "exhibition" (전시) / "blocked" (관리자 차단)
  exhibitionId String?  // 전시로 인한 경우 전시회 ID
  createdAt    DateTime @default(now())

  @@unique([date]) // 같은 날짜 중복 방지
}
